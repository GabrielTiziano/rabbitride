# ============================================================================
# RabbitRide — exemplo de variáveis de ambiente
# Copie para .env e ajuste os valores: cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_USER=rabbitride
POSTGRES_PASSWORD=rabbitride
POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ----------------------------------------------------------------------------
# RabbitMQ
# ----------------------------------------------------------------------------
RABBITMQ_USER=rabbitride
RABBITMQ_PASSWORD=rabbitride
RABBITMQ_AMQP_PORT=5672
RABBITMQ_UI_PORT=15672

# ----------------------------------------------------------------------------
# MailHog
# ----------------------------------------------------------------------------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ----------------------------------------------------------------------------
# Segurança (usado nas próximas milestones)
# ----------------------------------------------------------------------------
# Gere com: openssl rand -base64 64
JWT_SECRET=troque-isso-em-producao-use-um-secret-aleatorio-de-pelo-menos-256-bits

# Token compartilhado entre microsserviços para endpoints internos
INTERNAL_API_TOKEN=troque-isso-tambem-segredo-interno
